# Telegram Bot Configuration
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID (can be channel, group, or user)
# For channels: use the channel ID (e.g., -1001234567890)
# For groups: negative number of group ID
# For users: user's chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Honeypot paths
# HONEYPOT_DB_PATH=/root/honeypot-intel/data/honeypot.db
# HONEYPOT_LOG_PATH=/root/honeypot-intel/logs/pipeline.log
# HONEYPOT_SSH_HOST=CT100
